{
  "exclude": ["node_modules/"],
  "include": ["src/", "vite.config.ts"],
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",

    "types": ["vite/client", "node"],
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "jsx": "react-jsx",

    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": true,
    "skipLibCheck": true,

    "strict": true,
  }
}
